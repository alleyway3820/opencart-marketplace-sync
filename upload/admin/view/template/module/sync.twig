{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ preview }}" class="btn btn-primary"><i class="fa fa-search"></i> {{ text_preview }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-bg-primary">
          <div class="card-header"><h5 class="card-title"><i class="fa fa-cube"></i> {{ text_total_products }}</h5></div>
          <div class="card-body"><h3 class="text-end">{{ total_products }}</h3></div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-bg-success">
          <div class="card-header"><h5 class="card-title"><i class="fa fa-folder"></i> {{ text_total_categories }}</h5></div>
          <div class="card-body"><h3 class="text-end">{{ total_categories }}</h3></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><i class="fa fa-info-circle"></i> Marketplace Sync</div>
      <div class="card-body">
        <p>This tool syncs product listings from eBay and other marketplaces into your OpenCart store.</p>
        <p><a href="{{ preview }}" class="btn btn-primary"><i class="fa fa-search"></i> {{ text_preview }}</a></p>
      </div>
    </div>
  </div>
</div>
{{ footer }}
