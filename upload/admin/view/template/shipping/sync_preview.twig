{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ dashboard }}" class="btn btn-secondary"><i class="fa fa-home"></i> {{ text_dashboard }}</a>
      </div>
      <h1>{{ text_preview }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa fa-search"></i> Browse eBay Store</div>
      <div class="card-body">
        <form id="form-search" class="row g-3">
          <div class="col-md-3">
            <label class="form-label">{{ text_seller }}</label>
            <input type="text" name="seller" value="ageek4less" class="form-control" placeholder="eBay seller username"/>
          </div>
          <div class="col-md-3">
            <label class="form-label">{{ text_keyword }}</label>
            <input type="text" name="keyword" value="" class="form-control" placeholder="Leave blank to search all"/>
          </div>
          <div class="col-md-3">
            <label class="form-label">Category</label>
            <select name="category_id" class="form-control" id="category-select">
              <option value="">-- All Categories --</option>
            </select>
          </div>
          <div class="col-md-1">
            <label class="form-label">Per page</label>
            <select name="limit" class="form-control">
              <option value="25">25</option>
              <option value="50" selected>50</option>
              <option value="100">100</option>
              <option value="200">200</option>
            </select>
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100" id="button-search">
              <i class="fa fa-search"></i> {{ text_search_btn }}
            </button>
          </div>
          <input type="hidden" name="offset" value="0" id="input-offset"/>
        </form>
      </div>
    </div>
    
    <div id="results" class="mt-3" style="display:none">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><strong id="result-count">0</strong> items found</span>
          <nav id="pagination-controls" style="display:none">
            <ul class="pagination pagination-sm mb-0">
              <li class="page-item" id="prev-page"><a class="page-link" href="#">&laquo;</a></li>
              <li class="page-item disabled"><a class="page-link" id="page-info" href="#">Page 1</a></li>
              <li class="page-item" id="next-page"><a class="page-link" href="#">&raquo;</a></li>
            </ul>
          </nav>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped mb-0">
              <thead>
                <tr>
                  <th style="width:60px">Image</th>
                  <th>Title</th>
                  <th>Price</th>
                  <th>Condition</th>
                  <th>Status</th>
                  <th style="width:120px">Action</th>
                </tr>
              </thead>
              <tbody id="items-table-body"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    
    <div id="loading" class="text-center py-5" style="display:none">
      <div class="spinner-border text-primary" role="status"></div>
      <p class="mt-2">Searching eBay...</p>
    </div>
    
    <div id="error-message" class="alert alert-danger mt-3" style="display:none"></div>
  </div>
</div>

<script type="text/javascript">
var currentOffset = 0;
var currentTotal = 0;
var currentLimit = 50;

function doSearch(offset) {
    $('#loading').show();
    $('#results').hide();
    $('#error-message').hide();
    $('#input-offset').val(offset);
    currentOffset = offset;
    
    $.ajax({
        url: 'index.php?route=extension/opencart/shipping/sync.search&user_token={{ user_token }}',
        type: 'post',
        data: $('#form-search').serialize(),
        dataType: 'json',
        success: function(json) {
            $('#loading').hide();
            
            if (json['error']) {
                $('#error-message').html(json['error']).show();
                return;
            }
            
            // Update category dropdown
            var catSelect = $('#category-select');
            var currentCat = catSelect.val();
            catSelect.find('option[value!=""]').remove();
            if (json['categories']) {
                for (var k = 0; k < json['categories'].length; k++) {
                    var c = json['categories'][k];
                    catSelect.append('<option value="' + c['id'] + '">' + c['name'] + '</option>');
                }
                if (currentCat) catSelect.val(currentCat);
            }
            
            // Render items
            var html = '';
            var items = json['items'] || [];
            currentTotal = json['total'] || 0;
            currentLimit = json['limit'] || 50;
            
            for (var i = 0; i < items.length; i++) {
                var item = items[i];
                var isImported = item['status'] === 'Imported';
                var statusClass = isImported ? 'text-success' : 'text-primary';
                
                html += '<tr>';
                html += '<td>' + (item['image'] ? '<img src="' + item['image'] + '" style="max-width:50px;max-height:50px"/>' : '') + '</td>';
                html += '<td>' + item['title'] + '</td>';
                html += '<td>' + item['price'] + '</td>';
                html += '<td>' + item['condition'] + '</td>';
                html += '<td class="' + statusClass + '">' + item['status'] + '</td>';
                
                if (isImported) {
                    html += '<td><a href="index.php?route=catalog/product.form&user_token={{ user_token }}&product_id=' + item['product_id'] + '" class="btn btn-sm btn-info">View</a></td>';
                } else {
                    html += '<td><button class="btn btn-sm btn-success import-btn" data-id="' + item['id'] + '"><i class="fa fa-download"></i> Import</button></td>';
                }
                html += '</tr>';
            }
            
            if (items.length === 0) {
                html = '<tr><td colspan="6" class="text-center py-3">No items found</td></tr>';
            }
            
            $('#items-table-body').html(html);
            $('#result-count').text(currentTotal);
            
            // Pagination
            var totalPages = Math.ceil(currentTotal / currentLimit);
            if (totalPages > 1) {
                $('#pagination-controls').show();
                var pageNum = Math.floor(currentOffset / currentLimit) + 1;
                $('#page-info').text('Page ' + pageNum + ' of ' + totalPages);
                $('#prev-page').toggleClass('disabled', currentOffset <= 0);
                $('#next-page').toggleClass('disabled', currentOffset + currentLimit >= currentTotal);
            } else {
                $('#pagination-controls').hide();
            }
            
            $('#results').show();
        },
        error: function() {
            $('#loading').hide();
            $('#error-message').html('Request failed').show();
        }
    });
}

$('#form-search').on('submit', function(e) {
    e.preventDefault();
    doSearch(0);
});

$('#prev-page').on('click', function(e) {
    e.preventDefault();
    if (currentOffset > 0) doSearch(Math.max(0, currentOffset - currentLimit));
});

$('#next-page').on('click', function(e) {
    e.preventDefault();
    if (currentOffset + currentLimit < currentTotal) doSearch(currentOffset + currentLimit);
});

// Single import
$(document).on('click', '.import-btn', function() {
    var btn = $(this);
    var itemId = btn.data('id');
    btn.html('<span class="spinner-border spinner-border-sm"></span>').prop('disabled', true);
    
    $.ajax({
        url: 'index.php?route=extension/opencart/shipping/sync.importItem&user_token={{ user_token }}',
        type: 'post',
        data: { item_id: itemId },
        dataType: 'json',
        success: function(json) {
            if (json['success']) {
                btn.html('<i class="fa fa-check"></i> Done').removeClass('btn-success').addClass('btn-info');
                btn.closest('tr').find('td:nth-child(5)').text('Imported').removeClass('text-primary').addClass('text-success');
            } else {
                alert('Import failed: ' + (json['error'] || 'Unknown error'));
                btn.html('<i class="fa fa-download"></i> Import').prop('disabled', false);
            }
        },
        error: function() {
            alert('Request failed');
            btn.html('<i class="fa fa-download"></i> Import').prop('disabled', false);
        }
    });
});
</script>
{{ footer }}
