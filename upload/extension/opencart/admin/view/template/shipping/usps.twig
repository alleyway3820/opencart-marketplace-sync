{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-shipping" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-shipping" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label for="input-user-id" class="col-sm-2 col-form-label">{{ entry_user_id }}</label>
            <div class="col-sm-10">
              <input type="text" name="shipping_usps_user_id" value="{{ shipping_usps_user_id }}" placeholder="{{ entry_user_id }}" id="input-user-id" class="form-control"/>
              <div class="form-text text-muted"><small>{{ entry_user_id_help }}</small></div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-mode" class="col-sm-2 col-form-label">{{ entry_mode }}</label>
            <div class="col-sm-10">
              <select name="shipping_usps_mode" id="input-mode" class="form-select">
                <option value="test"{% if shipping_usps_mode == 'test' %} selected{% endif %}>{{ text_test }}</option>
                <option value="live"{% if shipping_usps_mode == 'live' %} selected{% endif %}>{{ text_live }}</option>
              </select>
              <div class="form-text text-muted"><small>{{ entry_mode_help }}</small></div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-debug" class="col-sm-2 col-form-label">{{ entry_debug }}</label>
            <div class="col-sm-10 pt-2">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="shipping_usps_debug" value="0"/>
                <input type="checkbox" name="shipping_usps_debug" value="1" id="input-debug" class="form-check-input"{% if shipping_usps_debug %} checked{% endif %}/>
              </div>
              <div class="form-text text-muted"><small>{{ entry_debug_help }}</small></div>
            </div>
          </div>

          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ text_enabled }}</label>
            <div class="col-sm-10 pt-2">
              <div class="mb-2">{{ help_services }}</div>
              <div class="form-check form-switch form-switch-lg mb-2">
                <input type="hidden" name="shipping_usps_ground_advantage" value="0"/>
                <input type="checkbox" name="shipping_usps_ground_advantage" value="1" id="input-ground-advantage" class="form-check-input"{% if shipping_usps_ground_advantage %} checked{% endif %}/>
                <label for="input-ground-advantage" class="form-check-label">{{ entry_ground_advantage }}</label>
              </div>
              <div class="form-check form-switch form-switch-lg mb-2">
                <input type="hidden" name="shipping_usps_priority_mail" value="0"/>
                <input type="checkbox" name="shipping_usps_priority_mail" value="1" id="input-priority-mail" class="form-check-input"{% if shipping_usps_priority_mail %} checked{% endif %}/>
                <label for="input-priority-mail" class="form-check-label">{{ entry_priority_mail }}</label>
              </div>
              <div class="form-check form-switch form-switch-lg mb-2">
                <input type="hidden" name="shipping_usps_priority_mail_express" value="0"/>
                <input type="checkbox" name="shipping_usps_priority_mail_express" value="1" id="input-priority-express" class="form-check-input"{% if shipping_usps_priority_mail_express %} checked{% endif %}/>
                <label for="input-priority-express" class="form-check-label">{{ entry_priority_express }}</label>
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-handling-fee" class="col-sm-2 col-form-label">{{ entry_handling_fee }}</label>
            <div class="col-sm-10">
              <div class="row">
                <div class="col-sm-6 mb-2">
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="text" name="shipping_usps_handling_fee" value="{{ shipping_usps_handling_fee }}" placeholder="0.00" id="input-handling-fee" class="form-control"/>
                  </div>
                  <div class="form-text text-muted"><small>{{ entry_handling_fee_help }}</small></div>
                </div>
                <div class="col-sm-6">
                  <div class="input-group">
                    <span class="input-group-text">%</span>
                    <input type="text" name="shipping_usps_handling_percentage" value="{{ shipping_usps_handling_percentage }}" placeholder="0" id="input-handling-percentage" class="form-control"/>
                  </div>
                  <div class="form-text text-muted"><small>{{ entry_handling_percentage_help }}</small></div>
                </div>
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-tax-class" class="col-sm-2 col-form-label">{{ entry_tax_class }}</label>
            <div class="col-sm-10">
              <select name="shipping_usps_tax_class_id" id="input-tax-class" class="form-select">
                <option value="0">{{ text_none }}</option>
                {% for tax_class in tax_classes %}
                  <option value="{{ tax_class.tax_class_id }}"{% if tax_class.tax_class_id == shipping_usps_tax_class_id %} selected{% endif %}>{{ tax_class.title }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-geo-zone" class="col-sm-2 col-form-label">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="shipping_usps_geo_zone_id" id="input-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == shipping_usps_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10 pt-2">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="shipping_usps_status" value="0"/>
                <input type="checkbox" name="shipping_usps_status" value="1" id="input-status" class="form-check-input"{% if shipping_usps_status %} checked{% endif %}/>
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="shipping_usps_sort_order" value="{{ shipping_usps_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
            </div>
          </div>

          <div class="card mt-4">
            <div class="card-header"><i class="fa-solid fa-weight-scale"></i> {{ entry_default_weight }}</div>
            <div class="card-body">
              <div class="form-text text-muted mb-3">{{ help_defaults }}</div>
              <div class="row mb-3">
                <label for="input-default-weight" class="col-sm-2 col-form-label">{{ entry_default_weight }}</label>
                <div class="col-sm-10">
                  <input type="text" name="shipping_usps_default_weight" value="{{ shipping_usps_default_weight }}" placeholder="4" id="input-default-weight" class="form-control"/>
                  <div class="form-text text-muted"><small>{{ entry_default_weight_help }}</small></div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-default-length" class="col-sm-2 col-form-label">{{ entry_default_length }}</label>
                <div class="col-sm-4">
                  <input type="text" name="shipping_usps_default_length" value="{{ shipping_usps_default_length }}" placeholder="7" id="input-default-length" class="form-control"/>
                </div>
                <label for="input-default-width" class="col-sm-2 col-form-label">{{ entry_default_width }}</label>
                <div class="col-sm-4">
                  <input type="text" name="shipping_usps_default_width" value="{{ shipping_usps_default_width }}" placeholder="4" id="input-default-width" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-default-height" class="col-sm-2 col-form-label">{{ entry_default_height }}</label>
                <div class="col-sm-4">
                  <input type="text" name="shipping_usps_default_height" value="{{ shipping_usps_default_height }}" placeholder="1" id="input-default-height" class="form-control"/>
                </div>
                <div class="col-sm-6">
                  <div class="form-text text-muted"><small>{{ entry_dimensions_help }}</small></div>
                </div>
              </div>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
