<!-- Products section -->
<div id="shop" style="max-width:1200px;margin:0 auto;padding:48px 32px;font-family:'Karla',sans-serif;">
  <div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
    <h2 style="font-family:'Passion One',sans-serif;font-size:34px;margin:0;color:#3d2a1a;">Shop the shelf</h2>
  </div>
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;">
    <a href="index.php?route=product/category&path=25" style="padding:9px 18px;border-radius:999px;border:2px solid #3d2a1a;font-weight:700;font-size:13px;background:#3d2a1a;color:#f4ecd8;text-decoration:none;">All Parts</a>
    <a href="index.php?route=product/category&path=60" style="padding:9px 18px;border-radius:999px;border:2px solid #3d2a1a;font-weight:700;font-size:13px;background:#fff;color:#3d2a1a;text-decoration:none;">Music</a>
    <a href="index.php?route=product/category&path=34" style="padding:9px 18px;border-radius:999px;border:2px solid #3d2a1a;font-weight:700;font-size:13px;background:#fff;color:#3d2a1a;text-decoration:none;">Electronics</a>
    <a href="index.php?route=product/category&path=18" style="padding:9px 18px;border-radius:999px;border:2px solid #3d2a1a;font-weight:700;font-size:13px;background:#fff;color:#3d2a1a;text-decoration:none;">Laptops</a>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:22px;">
    {% if products %}
      {% for product in products[:8] %}
        <div style="background:#fff;border:2px solid #3d2a1a;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;">
          <div style="height:150px;background:#eee1c6;display:flex;align-items:center;justify-content:center;">
            {% if product.thumb %}<img src="{{ product.thumb }}" style="max-width:100%;max-height:100%;object-fit:contain;" alt="{{ product.name }}">{% endif %}
          </div>
          <div style="padding:14px;display:flex;flex-direction:column;gap:6px;flex:1;">
            <div style="font-size:14px;font-weight:700;color:#3d2a1a;line-height:1.3;">{{ product.name }}</div>
            <div style="font-size:12px;color:#8a7455;">Used - Tested</div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:8px;">
              <span style="font-size:18px;font-weight:900;color:#a52c3c;font-family:'Passion One',sans-serif;">${{ product.price }}</span>
              <a href="{{ product.href }}" style="background:#3d2a1a;color:#f4ecd8;text-decoration:none;border:none;border-radius:8px;padding:8px 14px;font-weight:700;font-size:13px;display:inline-block;">View</a>
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div style="text-align:center;padding:60px 20px;color:#8a7455;font-size:15px;grid-column:1/-1;">No products yet — check back soon!</div>
    {% endif %}
  </div>
</div>

